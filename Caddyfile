# On-demand TLS validation — only provision certs for verified domains
{
    on_demand_tls {
        ask http://app:3000/api/domains/verify
    }
}

# Main domain — Cloudflare Origin Certificate
{$APP_DOMAIN:localhost} {
    tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin-key.pem
    reverse_proxy app:3000
}

# Custom domains — Let's Encrypt via on-demand TLS
# Restaurant custom domains point directly to this server (not through Cloudflare)
:443 {
    tls {
        on_demand
    }
    reverse_proxy app:3000
}

:80 {
    reverse_proxy app:3000
}
